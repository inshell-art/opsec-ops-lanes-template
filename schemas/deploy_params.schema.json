{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deploy Parameters",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "contract_name",
    "constructor_args"
  ],
  "properties": {
    "contract_name": {
      "type": "string"
    },
    "constructor_args": {
      "type": "object",
      "additionalProperties": true
    },
    "name": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "paymentToken": {
      "type": "string"
    },
    "treasury": {
      "type": "string"
    },
    "openTime": {
      "type": [
        "string",
        "number",
        "integer"
      ]
    },
    "startDelay": {
      "type": [
        "string",
        "number",
        "integer"
      ]
    },
    "pricing": {
      "type": [
        "object",
        "string",
        "number",
        "integer"
      ]
    },
    "tokenPerEpoch": {
      "type": [
        "string",
        "number",
        "integer"
      ]
    },
    "epochSeconds": {
      "type": [
        "string",
        "number",
        "integer"
      ]
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
